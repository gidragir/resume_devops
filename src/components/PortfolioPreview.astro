---
import type { CollectionEntry } from "astro:content"
import Pill from "@components/ui/Pill.astro"

import { format } from "date-fns";

interface Props {
  project: CollectionEntry<"work">;
}

const { data, slug } = Astro.props.project;
---

<a class="card" href={`/resume_devops/work/${slug}`}>
  <span class="title">{data.title}</span>
  <div class="flex flex-row justify-around">
    <Pill>{format(data.start, "MMMM yyyy")}</Pill>
    <Pill>{format(data.end, "MMMM yyyy")}</Pill>
  </div>
  <p class="whitespace-nowrap overflow-hidden text-ellipsis m-[0.5rem] p-[0.5rem 1rem] text-[--gray-200]">{data.description}</p>  
</a>

<style lang="scss">
  .card {
    display: flex;
    flex-direction: column;
    height: 11rem;
    max-width: 608px;
    background: var(--gradient-subtle);
    border: 1px solid var(--gray-800);
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    font-family: var(--font-brand);
    font-size: var(--text-lg);
    font-weight: 500;
    transition: box-shadow var(--theme-transition);

    &:hover {
      box-shadow: var(--shadow-md);
    }

    @media (min-width: 50em) {
      height: 22rem;
      border-radius: 1.5rem;
    }
  }

  .title {
    grid-area: 1 / 1 / 2 / 2;
    z-index: 1;
    margin: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--gray-999);
    color: var(--gray-200);
    border-radius: 0.375rem;

    @media (min-width: 50em) {
      border-radius: 0.9375rem;
    }
  }
</style>
