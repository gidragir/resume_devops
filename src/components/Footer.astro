const currentYear = new Date().getFullYear()
---

<footer>
  <div class="group">
    </p>
    <p>&copy; {currentYear} Ilya Balter</p>
  </div>
  <p class="socials">
    <a href="https://github.com/gidragir"> GitHub</a>
    <a href="www.linkedin.com/in/илья-балтер-02427723a"> LinkedIn</a>
    <a href="https://dly.to/5DHznxhbkuA"> DailyDev</a>
